;; genome-taste.edn — the FROZEN editorial layer of the grain genome.
;; Everything here is judgement, not fact: cluster assignment, grid placement,
;; human-readable roles/descriptions, the CQRS framing, macro signatures & purposes.
;; Facts (loc, deps, which macros/protocols exist, deprecation) come from the repo
;; via genome.bb and are merged over this. Regenerate/extend with the `grain-genome` skill.

{:clusters
 [{:key "apps"  :name "Apps & tooling" :var "--c-apps"  :desc "services, UI runtime, dev tooling"}
  {:key "write" :name "Write side"     :var "--c-write" :desc "commands & reactive processors"}
  {:key "read"  :name "Read side"      :var "--c-read"  :desc "projections & queries"}
  {:key "log"   :name "Event log"      :var "--c-log"   :desc "append-only spine + backends"}
  {:key "found" :name "Foundation"     :var "--c-found" :desc "shared primitives (bedrock)"}
  {:key "ops"   :name "Clients & ops"  :var "--c-ops"   :desc "terminal UI, observability"}]

 :cols [300 560 820 1080 1340 1600 1860 2120]
 :rows [180 375 570 765 960 1155]

 :zones [["write" 690 92] ["event log" 1080 92] ["read" 1700 92] ["foundation" 1080 1268]]

 :copy
 {:kick  "grain · current generation"
  :title "{{components}} live components,<br><b>one CQRS spine</b>"
  :lede  "The deprecated v2 lineage and the retired AI/behavior-tree cluster are removed — <b style=\"color:var(--ink)\">{{deprecated}} hidden</b>. What remains is a single generation: <b style=\"color:var(--c-write)\">commands</b> on the left, the <b style=\"color:var(--c-log)\">event log</b> down the middle, <b style=\"color:var(--c-read)\">reads</b> on the right, all on a shared foundation."}

