 ;; macro catalog: grouping + signature + purpose (taste). The defining component
 ;; is filled in deterministically by genome.bb from the repo.
 :macro-catalog
 {:groups
  [{:g "CQRS building blocks"
    :macros [{:m "defcommand"    :sig "(defcommand :area/name {…} [ctx] & body)"    :p "Handle a command → append events to the log"}
             {:m "defquery"      :sig "(defquery :area/name {…} [ctx] & body)"      :p "Answer a read-side query over projections"}
             {:m "defreadmodel"  :sig "(defreadmodel :area/name {…} [entity] & body)" :p "Fold events into a read-model projection"}
             {:m "defprocessor"  :sig "(defprocessor :area/name {…} [ctx] & body)"  :p "React to events; issue follow-up commands"}
             {:m "defperiodic"   :sig "(defperiodic :area/name {…} & body)"          :p "Run work on a schedule / interval"}
             {:m "defeventmodel" :sig "(defeventmodel :area {area-map})"             :p "Register a service-area event model spec"}]}
   {:g "Schema & tooling"
    :macros [{:m "defschemas" :sig "(defschemas sym {schema-map})" :p "Register a set of malli schemas"}
             {:m "defguide"   :sig "(defguide :id {…})"            :p "Author a dev / agent REPL guide"}]}
   {:g "UI · datastar"
    :macros [{:m "defcomponent"      :sig "(defcomponent name [args] & body)" :p "Define a hypermedia component (hiccup)"}
             {:m "with-signals"      :sig "(with-signals [open? {…}] & body)" :p "Declare reactive Datastar signals"}
             {:m "with-signal-scope" :sig "(with-signal-scope [scope] & body)" :p "Scope nested signal declarations"}]}]}

 ;; one-line purpose per protocol seam (definer + implementers come from the repo).
 :protocol-notes
 {"EventStore" "Append & read the append-only event log — the storage seam behind every write."
  "KVStore"    "Key-value storage for read-model projections."
  "PubSub"     "In-process event bus (self-implemented — no external backend)."}}
